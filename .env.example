# SISE2026 BPS Kabupaten Jember - Environment Configuration
# Salin file ini menjadi .env dan sesuaikan nilainya
# Catatan: Pengaturan database sekarang terdeteksi otomatis berdasarkan HTTP_HOST

# Application URL (optional - will auto-detect if not set)
# Local: http://localhost/se2026-jember
# Production: https://se2026.bpsjember.my.id
# APP_URL=http://localhost/se2026-jember

# Session Settings (optional)
SESSION_LIFETIME=7200
SESSION_SECURE=false  # Set to true in production with HTTPS

# File Upload Settings (optional)
MAX_UPLOAD_SIZE=5242880  # 5MB in bytes
